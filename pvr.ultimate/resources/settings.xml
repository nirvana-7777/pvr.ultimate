<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<settings version="1">
    <section id="main">
        <category id="backend" label="30010" help="">
            <group id="1" label="30011">
                <setting id="backend_url" type="string" label="30020" help="30021">
                    <level>0</level>
                    <default>127.0.0.1</default>
                    <control type="edit" format="string"/>
                </setting>
                <setting id="backend_port" type="integer" label="30030" help="30031">
                    <level>0</level>
                    <default>7777</default>
                    <constraints>
                        <minimum>1</minimum>
                        <maximum>65535</maximum>
                    </constraints>
                    <control type="spinner" format="integer"/>
                </setting>
            </group>
            <group id="2" label="30012">
                <setting id="retry_attempts" type="integer" label="30040" help="30041">
                    <level>1</level>
                    <default>10</default>
                    <constraints>
                        <minimum>1</minimum>
                        <maximum>30</maximum>
                    </constraints>
                    <control type="spinner" format="integer"/>
                </setting>
                <setting id="retry_delay" type="integer" label="30050" help="30051">
                    <level>1</level>
                    <default>2000</default>
                    <constraints>
                        <minimum>100</minimum>
                        <maximum>10000</maximum>
                        <step>100</step>
                    </constraints>
                    <control type="spinner" format="integer"/>
                </setting>
            </group>
        </category>

        <!-- NEW: EPG Service Settings -->
        <category id="epg" label="EPG Service" help="">
            <group id="3" label="EPG Source">
                <setting id="epg_enabled" type="bool" label="Use Database EPG Service" help="Enable to use database EPG service instead of backend API">
                    <level>0</level>
                    <default>false</default>
                    <control type="toggle"/>
                </setting>
                <setting id="epg_service_url" type="string" label="EPG Service URL" help="URL of the database EPG service (e.g., http://localhost:8080)">
                    <level>0</level>
                    <default>http://localhost:8080</default>
                    <enable>eq(1)</enable>
                    <control type="edit" format="string"/>
                </setting>
            </group>
        </category>
    </section>
</settings>